# Excluir directorios generados por Cargo
/target/
/debug/
/release/

# Archivos de la base de datos de Cargo (generados localmente)
**/*.rs.bk

# Archivos temporales de compilación
*.rs.bin
*.rs.rs
*.stderr

# Archivos compilados e intermedios
*.a
*.ko
*.obj
*.so
*.rlib
*.lib
*.dll
*.dylib
*.exe
*.out
*.app

# Archivos de bloqueo de dependencias
# (Solo ignorar si estás desarrollando una librería, descomentar la línea de abajo)
# Cargo.lock

# Archivos de símbolos de depuración
*.dSYM/
*.pdb

# Directorios de compilación y caché de compilación (salsa secreta de Cargo)
.rustc_info.json
*.o
